---
import Layout from '../layouts/Layout.astro'
import Header from '../components/ui/Header.astro'
import HeroVideo from '../components/ui/HeroVideo.astro'
import Footer from '../components/ui/Footer.astro'
import NossosPastores from '../components/ui/Nossos-pastores.astro'
import '../styles/global.css'
---

<Layout hero={true}>
  <Header transparent={true} animated={true} heroMode={true} />
  <HeroVideo />
  <NossosPastores />
  <!-- <Pastores /> -->
  <section class="libros">
    <h2 class="text-3xl md:text-4xl font-extrabold uppercase text-white">Adquira nossos livros</h2>

    <article class="libros-container">
      <div class="libro">
        <a href="#"><img src="/libros/onde-estao.png" alt="Onde estão os Elias de Deus" /></a>
      </div>

      <div class="libro">
        <a href="#"
          ><img
            src="/libros/jesus-regresa-pronto.webp"
            alt="Jesus regresa pronto"
          /></a
        >
      </div>

      <div class="libro">
        <a href="#"
          ><img
            src="/libros/cultivando.webp"
            alt="Cultivando"
          /></a
        >
      </div>
      <div class="libro">
        <a href="#"
          ><img
            src="/libros/la-gloria-de-dios.webp"
            alt="La gloria de Dios"
          /></a
        >
      </div>
    </article>
  </section>
  <!-- <Ubicacion /> -->
  <Footer />
</Layout>
