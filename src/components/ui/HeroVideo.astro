---
import Header from './Header.astro'
---

<section class="hero-section relative w-full overflow-hidden">
  <video
    class="absolute top-0 left-0 w-full h-full object-cover will-change-transform"
    autoplay
    muted
    loop
    playsinline
    poster="/hero-poster.jpg"
    preload="metadata"
    webkit-playsinline
  >
    <source src="/hero-video-opt.webm" type="video/webm" />
    <source src="/hero-video-opt-new.mp4" type="video/mp4" />
  </video>
  <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
    <img
      id="hero-logo"
      src="/logo-gdc.png"
      alt="logo"
      class="animate-fade-in-up w-80 md:w-2xl lg:w-2xl"
    />
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    min-height: 100dvh;
    overflow: hidden;
  }

  .hero-section video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero-section {
      height: 100%;
    }
  }
</style>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const video = document.querySelector('.hero-section video')
    if (!video) return

    video.muted = true
    video.play().catch(() => {
      // Safari bloqueó el autoplay, intentar de nuevo con interacción
      document.addEventListener('touchstart', () => video.play(), { once: true })
      document.addEventListener('click', () => video.play(), { once: true })
    })
  })
</script>