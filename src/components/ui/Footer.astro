---
import RedesSociales from "./RedesSociales.astro";


---

<footer class="bg-black/90 backdrop-blur-md text-white min-h-80 py-8 flex flex-col justify-between">
  <div class="flex flex-col items-center md:flex-row md:justify-around md:items-center mt-12 gap-2">
    <!-- Logo y descripción -->
    <div class="w-80 flex flex-col justify-center items-center">
      <a href="/"><img src="/logo-bola.png" alt="logo" class="w-50"></a>
      <p class="mt-4 text-center text-sm">
        Somos uma igreja de conquista, que busca inspirar e guiar pessoas a buscar a verdade, a justiça e a paz.
      </p>
    </div>

    <!-- Redes sociales -->
    <div class="flex flex-col justify-center items-center gap-2 mt-6 md:mt-0">
      <h3 class="font-medium lg:text-[17px]">Siga-nos nas redes sociais</h3>
      <RedesSociales />
    </div>
  </div>

  <!-- Copyright -->
  <p class="text-center text-sm md:text-base pt-8">
    Copyright © <span id="year"></span> | Geração de Conquista Church
  </p>
</footer>

<script is:inline>
  document.getElementById('year').textContent = new Date().getFullYear();
</script>