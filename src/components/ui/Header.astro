---
import '../../styles/global.css'
import MainNav from './MainNav.astro'
import RedesSociales from './RedesSociales.astro'

const {
  transparent = false,
  animated = false,
  dark = false,
  heroMode = false,
} = Astro.props
---

<header
  id="main-header"
  data-transparent={transparent}
  class=`${animated ? 'animate-fade-in-up': ''} fixed top-0 left-0 inset-x-0 w-full box-border ${dark ? 'text-black' : 'text-white'} min-h-20 flex items-center justify-between z-[60] transition-[background-color,box-shadow,color] duration-300 ${transparent ? '' : 'header-scrolled'} header-dark`
  data-dark={dark}
  data-scrolled="false"
>
  <!-- LOGO -->
  <a href="/" class="relative z-[80]">
    <!-- Logo solo texto (visible si heroMode) -->
    <img
      id="header-logo"
      src="/logo-text.png"
      class={`w-36 absolute top-1/2 left-0 -translate-y-1/2 transition-opacity duration-500 ${dark ? 'invert' : ''}`}
      style={`opacity: ${heroMode ? '1' : '0'};`}
    />
    <!-- Logo completo (visible por defecto) -->
    <img
      id="header-logo-full"
      src="/logo-gdc.png"
      class="w-36 absolute top-1/2 left-0 -translate-y-1/2 transition-opacity duration-500"
      style={`opacity: ${heroMode ? '0' : '1'};`}
    />
    <!-- Spacer para que el <a> tenga dimensiones -->
    <span class="block w-36 h-10 invisible"></span>
  </a>

  <!-- NAV (solo desktop) -->
  <div>
    <MainNav {dark} />
  </div>

  <!-- MENU BUTTON (solo mobile) -->
  <button
    id="menu-btn"
    class="max-[860px]:flex hidden text-2xl cursor-pointer relative z-[80]"
  >
    <i id="menu-icon" class="fa-solid fa-bars transition-all duration-300"></i>
  </button>
</header>

<script is:inline>
  window.addEventListener('load', () => {
    if (window.AOS) AOS.init({ once: true, duration: 800 })
  })

  document.addEventListener('astro:page-load', () => {
    if (window.AOS) AOS.refreshHard()
  })
</script>

<script is:inline>
  function initMobileMenu() {
    const btn = document.querySelector('#menu-btn')
    const menu = document.querySelector('#mobile-menu')
    const header = document.querySelector('#main-header')
    const logoText = document.querySelector('#header-logo')
    const logoFull = document.querySelector('#header-logo-full')

    if (!btn || !menu || !header) return

    function setLogosInvert(invert) {
      if (logoText) logoText.classList.toggle('invert', invert)
      if (logoFull) logoFull.classList.toggle('invert', invert)
    }

    // Reset estado
    menu.classList.remove('max-h-[500px]', 'pt-6', 'pb-8')
    menu.classList.add('max-h-0')
    header.classList.remove('header-menu-open')

    const newBtn = btn.cloneNode(true)
    btn.parentNode.replaceChild(newBtn, btn)

    const icon = newBtn.querySelector('#menu-icon')
    if (!icon) return

    icon.classList.add('fa-bars')
    icon.classList.remove('fa-xmark', 'rotate-90')

    newBtn.addEventListener('click', () => {
      const willOpen = menu.classList.contains('max-h-0')

      if (willOpen) {
        menu.classList.remove('max-h-0')
        menu.classList.add('max-h-[500px]', 'pt-6', 'pb-8')
        header.classList.add('header-scrolled', 'header-menu-open')
        // Logo siempre sin invert cuando menú abierto
        setLogosInvert(false)
      } else {
        menu.classList.remove('max-h-[500px]', 'pt-6', 'pb-8')
        menu.classList.add('max-h-0')
        header.classList.remove('header-menu-open')
        // Restaurar según dark y scroll
        const isDark = header.dataset.dark === 'true'
        setLogosInvert(isDark && window.scrollY <= 50)
        if (header.dataset.transparent === 'true' && window.scrollY <= 50) {
          header.classList.remove('header-scrolled')
        }
      }

      icon.classList.toggle('fa-bars')
      icon.classList.toggle('fa-xmark')
      icon.classList.toggle('rotate-90')
    })

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.remove('max-h-[500px]', 'pt-6', 'pb-8')
        menu.classList.add('max-h-0')
        header.classList.remove('header-menu-open')
        icon.classList.add('fa-bars')
        icon.classList.remove('fa-xmark', 'rotate-90')

        const isDark = header.dataset.dark === 'true'
        setLogosInvert(isDark && window.scrollY <= 50)

        if (header.dataset.transparent === 'true' && window.scrollY <= 50) {
          header.classList.remove('header-scrolled')
        }
      })
    })
  }

  document.addEventListener('astro:page-load', initMobileMenu)
</script>

<script is:inline data-hero-mode={heroMode}>
  (function () {
    const heroMode = document.currentScript?.dataset.heroMode === 'true'

    let currentObserver = null // 👈 guardamos referencia al observer activo

    function initHeroLogoObserver() {
      if (!heroMode) return

      // Desconectar observer anterior si existe
      if (currentObserver) {
        currentObserver.disconnect()
        currentObserver = null
      }

      const heroLogo = document.getElementById('hero-logo')
      const logoText = document.getElementById('header-logo')
      const logoFull = document.getElementById('header-logo-full')

      if (!heroLogo || !logoText || !logoFull) return

      currentObserver = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            logoText.style.opacity = '1'
            logoFull.style.opacity = '0'
          } else {
            logoText.style.opacity = '0'
            logoFull.style.opacity = '1'
          }
        },
        {
          rootMargin: '-80px 0px 0px 0px',
          threshold: 0,
        },
      )

      currentObserver.observe(heroLogo)
    }

    document.addEventListener('astro:page-load', initHeroLogoObserver)
  })()
</script>
