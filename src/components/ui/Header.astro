---
import '../../styles/global.css'
import MainNav from './MainNav.astro'
import RedesSociales from './RedesSociales.astro'

const { transparent = false, animated = false } = Astro.props
---

<header
  id="main-header"
  data-transparent={transparent}
  class=`${animated ? 'animate-fade-in-up': ''} fixed top-0 left-0 inset-x-0 w-full box-border text-white min-h-20 flex items-center justify-between md:justify-around px-6 md:px-16 lg:px-30 z-[60] transition-all duration-300 ${transparent ? '' : 'header-scrolled'}`
>
  <!-- LOGO -->
  <a href="/" class="relative z-[80]">
    <img src="/logo-bola.png" class="w-36" />
  </a>

  <div>
    <MainNav />
  </div>

  <!-- RIGHT SIDE -->
  <div class="flex items-center gap-6">
    <!-- MENU BUTTON (solo mobile) -->
    <button id="menu-btn" class="md:hidden text-2xl cursor-pointer relative z-[80]">
      <i id="menu-icon" class="fa-solid fa-bars transition-all duration-300"
      ></i>
    </button>

    <!-- REDES (solo desktop grande) -->
    <div class="hidden lg:flex">
      <RedesSociales />
    </div>
  </div>
</header>


<script is:inline>
  window.addEventListener('load', () => {
    if (window.AOS) AOS.init({ once: true, duration: 800 })
  })

  // Solo refrescar AOS después de la navegación SPA
  document.addEventListener('astro:page-load', () => {
    if (window.AOS) AOS.refreshHard()
  })
</script>

<script is:inline>
function initMobileMenu() {
  const btn = document.querySelector('#menu-btn');
  const menu = document.querySelector('#mobile-menu');
  const header = document.querySelector('#main-header');
  if (!btn || !menu || !header) return;

  // Reset estado
  menu.classList.add('hidden');

  // Clonar ANTES de buscar el icon
  const newBtn = btn.cloneNode(true);
  btn.parentNode.replaceChild(newBtn, btn);

  // Buscar icon DESPUÉS del clone
  const icon = newBtn.querySelector('#menu-icon');
  if (!icon) return;

  icon.classList.add('fa-bars');
  icon.classList.remove('fa-xmark', 'rotate-90');

  newBtn.addEventListener('click', () => {
    const willOpen = menu.classList.contains('hidden');

    if (willOpen) {
      menu.classList.remove('hidden');
      if (header.dataset.transparent === 'true' && window.scrollY <= 50) {
        header.classList.add('header-scrolled');
      }
    } else {
      menu.classList.add('hidden');
      if (header.dataset.transparent === 'true' && window.scrollY <= 50) {
        header.classList.remove('header-scrolled');
      }
    }

    icon.classList.toggle('fa-bars');
    icon.classList.toggle('fa-xmark');
    icon.classList.toggle('rotate-90');
  });

  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      icon.classList.add('fa-bars');
      icon.classList.remove('fa-xmark', 'rotate-90');

      if (header.dataset.transparent === 'true' && window.scrollY <= 50) {
        header.classList.remove('header-scrolled');
      }
    });
  });
}

document.addEventListener('astro:page-load', initMobileMenu);
</script>
