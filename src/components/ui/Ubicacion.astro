---

<section id="ubicacion" class="ubicacion py-20 bg-mist-50 rounded-3xl shadow-xl">
  <div
    class="container mx-auto px-6 md:px-16 lg:px-32 flex flex-col md:flex-row items-center gap-10"
  >
    <!-- Información de la iglesia -->
    <div class="flex-1 flex flex-col gap-4 text-center md:text-left">
      <h2
        class="text-3xl md:text-4xl font-bold text-gray-800 animate-fade-in-up uppercase"
      >
        Onde estamos
      </h2>
      <p class="text-gray-600 max-w-md">
        Geração de Conquista Church<br />
        Av. dos Tarumãs 2564, Sinop, Brazil
      </p>
      <p class="text-gray-600 max-w-md">
        Nossas reuniões: <br>
        Quinta Feira 19:30 hrs e Domingo 19:00 hrs
      </p>
      <a
        href="https://maps.app.goo.gl/cb1zpR58RLku3bmT7"
        target="_blank"
        class="mt-4 inline-flex items-center gap-2 bg-white text-gray-800 font-semibold px-6 py-3 rounded-full shadow-md hover:shadow-xl hover:scale-105 transition-transform duration-300"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17.657 16.657L13.414 12l4.243-4.243m-5.657 8.486L6 12l6-6 6 6-6 6z"
          ></path>
        </svg>
        Abrir en Google Maps
      </a>
    </div>

    <!-- Mapa -->
    <div
      class="flex-1 w-full h-80 md:h-96 rounded-xl overflow-hidden shadow-2xl border border-gray-200"
    >
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3904.6403354366653!2d-55.52441391981838!3d-11.86042995835441!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x93a77f8ea3d42d35%3A0xec230659584936a0!2sAv%20dos%20Tarum%C3%A3s%2C%202564%20-%20Jardim%20Maring%C3%A1%2C%20Sinop%20-%20MT%2C%2078556-250%2C%20Brasil!5e0!3m2!1ses-419!2scl!4v1773629045712!5m2!1ses-419!2scl"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </div>
</section>


