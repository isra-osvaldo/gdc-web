<section id="ubicacion" class="ubicacion relative py-24" data-aos="fade-zoom-in">
  <div class="custom-shape-divider-top-1773699232 hidden md:block">
    <svg
      data-name="Layer 1"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1200 120"
      preserveAspectRatio="none"
    >
      <path
        d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z"
        class="shape-fill"></path>
    </svg>
  </div>

  <div class="container mx-auto px-6 md:px-16 lg:px-32">
    <!-- TITULO -->
    <div class="text-center mb-16">
      <h2
        class="text-4xl md:text-5xl font-extrabold uppercase text-gray-800 text-white md:mt-12"
      >
        Onde estamos
      </h2>
      <p class="text-gray-200 mt-3">
        Venha nos visitar e fazer parte desta família
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- INFO CARD -->
      <div
        class="bg-transparent p-10 rounded-2xl shadow-2xl flex flex-col gap-6"
      >
        <div>
          <h3 class="text-xl font-bold text-white mb-2">
            Geração de Conquista Church
          </h3>
          <p class="text-gray-200">
            <i
              class="fa-solid fa-location-dot"
              style="color: rgb(247, 245, 245);"></i>
            Av. dos Tarumãs 2564 <br />
            Jardim Maringá – Sinop, MT
          </p>
        </div>

        <div>
          <h4 class="font-semibold text-white mb-2">Nossas reuniões</h4>

          <p class="text-gray-200">Quinta-feira • 19:30 hrs</p>

          <p class="text-gray-200">Domingo • 19:00 hrs</p>
        </div>

        <!-- BOTON -->
        <a
          href="https://maps.app.goo.gl/cb1zpR58RLku3bmT7"
          target="_blank"
          class="mt-4 inline-block bg-amber-400 text-black font-semibold px-8 py-4 rounded-full shadow-lg hover:bg-amber-200 hover:scale-105 transition-all duration-300 text-center"
        >
          Ver no Google Maps
        </a>
      </div>

      <!-- MAPA -->
      <div
        class="relative w-full h-[350px] md:h-[420px] rounded-2xl overflow-hidden shadow-2xl"
      >
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3904.6403354366653!2d-55.52441391981838!3d-11.86042995835441!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x93a77f8ea3d42d35%3A0xec230659584936a0!2sAv%20dos%20Tarum%C3%A3s%2C%202564%20-%20Jardim%20Maring%C3%A1%2C%20Sinop%20-%20MT%2C%2078556-250%2C%20Brasil!5e0!3m2!1ses-419!2scl!4v1773629045712!5m2!1ses-419!2scl"
          width="100%"
          height="100%"
          style="border:0;"
          loading="lazy"></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .ubicacion {
    background-image: linear-gradient(
      to right top,
      #293242,
      #384558,
      #46596e,
      #556e85,
      #64849d
    );
  }

  .custom-shape-divider-top-1773699232 {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }

  .custom-shape-divider-top-1773699232 svg {
    position: relative;
    display: block;
    width: calc(180% + 1.3px);
    height: 150px;
  }

  .custom-shape-divider-top-1773699232 .shape-fill {
    fill: #ffffff;
  }
</style>
